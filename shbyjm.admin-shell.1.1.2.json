{
    "manifests": {
        "shbyjm/admin-shell": {
            "manifest": {
                "bundles": {
                    "Shbyjm\\AdminShell\\ShbyjmAdminShellBundle": ["all"]
                },
                "env": {
                    "DEFAULT_URI": "https://your-site.example.com",
                    "MESSENGER_TRANSPORT_DSN": "doctrine://default?auto_setup=0"
                },
                "copy-from-recipe": {
                    "config/": "%CONFIG_DIR%/",
                    "public_html/": "public_html/"
                },
                "gitignore": [
                    "/public_html/uploads/admin-shell/*",
                    "!/public_html/uploads/admin-shell/.gitkeep"
                ],
                "post-install-output": [
                    "",
                    "  <fg=green>shbyjm/admin-shell</> installed.",
                    "",
                    "  <fg=yellow>⚠ messenger.yaml has been overwritten</> with the SHbyJM standard config",
                    "  (command.bus + async.bus + doctrine_transaction middleware).",
                    "  If you had custom Messenger configuration, re-integrate it manually.",
                    "",
                    "  - Configure <fg=yellow>DEFAULT_URI</> in <fg=yellow>.env.local</> with your site URL",
                    "  - Configure <fg=yellow>MESSENGER_TRANSPORT_DSN</> in <fg=yellow>.env.local</> (default: doctrine://default?auto_setup=0)",
                    "  - Edit <fg=yellow>config/packages/shbyjm_admin_shell.yaml</> to set your <fg=yellow>app_name</>",
                    "  - Add the Doctrine migrations path to <fg=yellow>config/packages/doctrine_migrations.yaml</>:",
                    "      <fg=cyan>'Shbyjm\\AdminShell\\Migrations': '%kernel.project_dir%/vendor/shbyjm/admin-shell/migrations'</>",
                    "  - Run <fg=yellow>php bin/console doctrine:migrations:migrate</>"
                ]
            },
            "files": {
                "config/packages/shbyjm_admin_shell.yaml": {
                    "contents": [
                        "shbyjm_admin_shell:",
                        "    app_name: 'My Site'",
                        "    default_uri: '%env(DEFAULT_URI)%'",
                        "    upload_dir: '%kernel.project_dir%/../public_html/uploads/admin-shell'",
                        "    upload_web_prefix: '/uploads/admin-shell'"
                    ],
                    "executable": false
                },
                "config/packages/messenger.yaml": {
                    "contents": [
                        "framework:",
                        "    messenger:",
                        "        default_bus: command.bus",
                        "        failure_transport: failed",
                        "        transports:",
                        "            async:",
                        "                dsn: '%env(MESSENGER_TRANSPORT_DSN)%'",
                        "                options:",
                        "                    queue_name: default",
                        "                retry_strategy:",
                        "                    max_retries: 3",
                        "                    multiplier: 2",
                        "            failed: 'doctrine://default?queue_name=failed'",
                        "        buses:",
                        "            command.bus:",
                        "                middleware:",
                        "                    - doctrine_transaction",
                        "            async.bus:",
                        "                default_middleware: allow_no_handlers",
                        "        routing:",
                        "            Symfony\\Component\\Mailer\\Messenger\\SendEmailMessage: async",
                        "",
                        "when@test:",
                        "    framework:",
                        "        messenger:",
                        "            transports:",
                        "                async: 'in-memory://'"
                    ],
                    "executable": false
                },
                "public_html/uploads/admin-shell/.gitkeep": {
                    "contents": [],
                    "executable": false
                }
            },
            "ref": "%%REF%%"
        }
    }
}
